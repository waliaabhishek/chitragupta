# Confluent Cloud credentials (for config-ccloud.yaml)
CCLOUD_ORG_ID=org-xxxxx
CCLOUD_API_KEY=your-api-key
CCLOUD_API_SECRET=your-api-secret

# Self-managed Kafka (for config-self-managed.yaml)
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# PROMETHEUS_URL=http://prometheus:9090

# Grafana admin password (optional — defaults to "password")
# GF_ADMIN_PASSWORD=changeme
