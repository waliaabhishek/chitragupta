# Confluent Cloud (required)
CCLOUD_TENANT_ID=ccloud-prod    # internal partition key (any string, not the CCloud org ID)
CCLOUD_API_KEY=ABCDEFGHIJ123456
CCLOUD_API_SECRET=your+api+secret+here

# Prometheus metrics (required when metrics block is present)
PROMETHEUS_URL=http://prometheus:9090
PROM_USERNAME=admin
PROM_PASSWORD=changeme

# Optional
# LOG_LEVEL=INFO
