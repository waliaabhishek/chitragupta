# CCloud credentials (required)
CCLOUD_TENANT_ID=ccloud-prod    # internal partition key (any string, not the CCloud org ID)
CCLOUD_API_KEY=ABCDEFGHIJ123456
CCLOUD_API_SECRET=your+api+secret+here

# Flink regional credentials (one pair per active region)
FLINK_US_KEY=FLINK_US_KEY_HERE
FLINK_US_SECRET=flink+us+secret+here
FLINK_EU_KEY=FLINK_EU_KEY_HERE
FLINK_EU_SECRET=flink+eu+secret+here

# Optional
# LOG_LEVEL=INFO
