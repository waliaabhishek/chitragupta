# Production tenant (required)
CCLOUD_PROD_TENANT_ID=ccloud-prod    # internal partition key (any string, not the CCloud org ID)
CCLOUD_PROD_API_KEY=PROD_KEY_HERE
CCLOUD_PROD_API_SECRET=prod+secret+here

# Staging tenant (required)
CCLOUD_STAGING_TENANT_ID=ccloud-staging  # internal partition key (any string, not the CCloud org ID)
CCLOUD_STAGING_API_KEY=STAGING_KEY_HERE
CCLOUD_STAGING_API_SECRET=staging+secret+here

# Optional
# LOG_LEVEL=INFO
