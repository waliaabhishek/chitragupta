# ── Prometheus URL ────────────────────────────────────────────────────────────
# Required. Must be reachable from inside the Docker network.
# Prometheus must be scraping Kafka brokers via prometheus-jmx-exporter.
# See deployables/assets/prometheus_for_chargeback/collector.sh for a helper script.
PROMETHEUS_URL=http://prometheus:9090

# ── Prometheus authentication (optional) ─────────────────────────────────────
# Required only if auth_type in config.yaml is set to "basic" or "bearer".
# PROMETHEUS_USERNAME=your-username
# PROMETHEUS_PASSWORD=your-password
# PROMETHEUS_TOKEN=your-bearer-token

# ── Kafka Admin API credentials (optional) ────────────────────────────────────
# Required only if resource_source.source is set to "admin_api" in config.yaml.
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# KAFKA_USERNAME=your-kafka-user
# KAFKA_PASSWORD=your-kafka-password

# ── Grafana admin password (optional) ────────────────────────────────────────
# Defaults to "password" if not set. Change before exposing Grafana externally.
# GF_ADMIN_PASSWORD=changeme
