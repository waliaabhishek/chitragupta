# ── Confluent Cloud API credentials ──────────────────────────────────────────
# Required. Create a Cloud API key in Confluent Cloud Console.
# The key must have MetricsViewer + BillingAdmin roles.
CCLOUD_API_KEY=your-api-key
CCLOUD_API_SECRET=your-api-secret

# ── Internal tenant identifier ────────────────────────────────────────────────
# This is NOT your Confluent Cloud organization ID.
# It's an internal partition key used to namespace DB records — any unique string works.
# If you run multiple tenants, each must have a distinct tenant_id.
CCLOUD_TENANT_ID=ccloud-prod

# ── Grafana admin password (optional) ────────────────────────────────────────
# Defaults to "password" if not set. Change before exposing Grafana externally.
# GF_ADMIN_PASSWORD=changeme

# ── Prometheus URL (optional) ─────────────────────────────────────────────────
# Required only if you uncomment the `metrics:` block in config.yaml.
# Must be reachable from within the Docker network.
# PROMETHEUS_URL=http://prometheus:9090

# ── Flink API credentials (optional) ─────────────────────────────────────────
# Required only if you uncomment the `flink:` block in config.yaml.
# FLINK_REGION_ID=us-east-1
# FLINK_API_KEY=your-flink-api-key
# FLINK_API_SECRET=your-flink-api-secret
